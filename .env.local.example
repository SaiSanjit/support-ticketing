# Empty = use MSW mock API. Set to real backend URL when ready. Zero component changes required.
VITE_API_URL=

# Empty = noop WebSocket stub. Set to Socket.IO server URL to activate real-time.
VITE_WS_URL=

# Enable push notification subscription and permission flow.
VITE_ENABLE_PUSH=false

# Enable AI features: natural language task creation, thread summariser.
VITE_ENABLE_AI=false

# VAPID public key for Web Push Notifications.
VITE_VAPID_KEY=

# development | staging | production
VITE_APP_ENV=development
